{
  "name": "neon",
  "colors": {
    "bg": "#050505",
    "accent": "#00F3FF",
    "secondary": "#FF003C",
    "text": "#E0E0E0",
    "grid": "#1A1A1A"
  },
  "palette": [
    "#00F3FF",
    "#FF003C",
    "#00FF41",
    "#FF9500",
    "#9D00FF",
    "#FFEA00"
  ],
  "settings": {
    "alpha": 0.3,
    "op": 0.3,
    "font": "monospace"
  },
  "matplotlib": {
    "figure.facecolor": "#050505",
    "axes.facecolor": "#050505",
    "axes.edgecolor": "#FF003C",
    "axes.labelcolor": "#E0E0E0",
    "axes.titlesize": 10,
    "axes.titleweight": "bold",
    "grid.color": "#1A1A1A",
    "grid.alpha": 0.3,
    "grid.linestyle": ":",
    "xtick.color": "#E0E0E0",
    "ytick.color": "#E0E0E0",
    "text.color": "#E0E0E0",
    "font.family": "monospace",
    "axes.spines.top": false,
    "axes.spines.right": false,
    "lines.color": "#00F3FF",
    "lines.marker": "s",
    "lines.markersize": 4,
    "patch.facecolor": "#00F3FF",
    "patch.edgecolor": "#050505",
    "scatter.marker": "s",
    "scatter.edgecolors": "#00F3FF"
  },
  "plotly": {
    "paper_bgcolor": "#050505",
    "plot_bgcolor": "#050505",
    "font_color": "#E0E0E0",
    "font_family": "Roboto Mono, Cascadia Code, Source Code Pro, Courier New, monospace",
    "grid_color": "#1A1A1A",
    "axis_line_color": "#FF003C"
  }
}
